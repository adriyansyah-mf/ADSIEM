FROM golang:1.23-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /siem-agent ./cmd/agent/

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    dpkg-dev \
    rpm \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /siem-agent /tmp/siem-agent
COPY packaging/build.sh /tmp/build.sh
RUN chmod +x /tmp/build.sh
CMD ["/tmp/build.sh"]
